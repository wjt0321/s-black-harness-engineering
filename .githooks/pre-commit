#!/bin/bash
# ============================================================
# pre-commit hook — docs 维护检查
# WARNING 级别：不阻止提交，只输出警告
# ============================================================

set -e

# 只在有 docs/ 变更时才运行
if ! git diff --cached --name-only | grep -q "^docs/"; then
    exit 0
fi

WARNINGS=0

echo ""
echo "=== docs maintenance check ==="

# ----------------------------------------------------------
# Check 1: 000-stage-digest 过期检查
#   如果 000-stage-digest.md 的最近修改落后 HEAD 超过 10 个 commit
# ----------------------------------------------------------
DIGEST="docs/000-stage-digest.md"
if [ -f "$DIGEST" ]; then
    DIGEST_HASH=$(git log -1 --format="%H" -- "$DIGEST" 2>/dev/null || echo "")
    if [ -n "$DIGEST_HASH" ]; then
        BEHIND=$(git rev-list --count "$DIGEST_HASH..HEAD" 2>/dev/null || echo "0")
        if [ "$BEHIND" -gt 10 ]; then
            echo "⚠️  WARNING: $DIGEST is $BEHIND commits behind HEAD — consider updating"
            WARNINGS=$((WARNINGS + 1))
        fi
    fi
fi

# ----------------------------------------------------------
# Check 2: 新增 .md 文件是否有 00-index 条目
# ----------------------------------------------------------
INDEX="docs/00-index.md"
NEW_DOCS=$(git diff --cached --diff-filter=A --name-only | grep "^docs/[0-9].*\.md$" || true)
if [ -n "$NEW_DOCS" ] && [ -f "$INDEX" ]; then
    while IFS= read -r doc; do
        BASENAME=$(basename "$doc")
        if ! grep -q "$BASENAME" "$INDEX" 2>/dev/null; then
            echo "⚠️  WARNING: new doc '$BASENAME' not found in $INDEX — add an entry"
            WARNINGS=$((WARNINGS + 1))
        fi
    done <<< "$NEW_DOCS"
fi

# ----------------------------------------------------------
# Check 3: docs/ 根目录 .md 文件数超标
# ----------------------------------------------------------
DOCS_COUNT=$(find docs/ -maxdepth 1 -name "*.md" | wc -l)
if [ "$DOCS_COUNT" -gt 50 ]; then
    echo "⚠️  WARNING: docs/ has $DOCS_COUNT .md files (threshold: 50) — consider archiving"
    WARNINGS=$((WARNINGS + 1))
fi

if [ "$WARNINGS" -gt 0 ]; then
    echo "=== $WARNINGS warning(s) found (non-blocking) ==="
    echo ""
else
    echo "✅ docs maintenance check passed"
    echo ""
fi

exit 0
