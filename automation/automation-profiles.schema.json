{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "control-plane/automation-profiles/v1",
  "title": "Automation Profile Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "profiles"],
  "properties": {
    "schema_version": {
      "const": "control-plane/automation-profiles/v1"
    },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "profile_id",
          "description",
          "required_contracts",
          "allow_preview",
          "max_access"
        ],
        "properties": {
          "profile_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240
          },
          "required_contracts": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9_]*$"
            }
          },
          "allow_preview": {
            "type": "boolean"
          },
          "max_access": {
            "enum": ["read_only", "controlled_write"]
          }
        }
      }
    }
  }
}
