{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-runtime.local/schemas/agents.schema.json",
  "title": "Agent Runtime Agent Registry",
  "type": "object",
  "required": ["version", "agents"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "description": {
      "type": "string"
    },
    "agents": {
      "type": "array",
      "items": { "$ref": "#/$defs/agent" },
      "minItems": 1
    }
  },
  "$defs": {
    "agent": {
      "type": "object",
      "required": ["id", "name", "role", "enabled", "workspace", "runtime", "capabilities"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "minLength": 1
        },
        "enabled": {
          "type": "boolean"
        },
        "workspace": {
          "type": "string",
          "minLength": 1
        },
        "runtime": {
          "$ref": "#/$defs/runtime"
        },
        "capabilities": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "default_tasks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "avoid_tasks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "hard_boundaries": {
          "type": "array",
          "items": { "type": "string" }
        },
        "handoff": {
          "$ref": "#/$defs/handoff"
        },
        "cost_profile": {
          "$ref": "#/$defs/cost_profile"
        },
        "policy_profile": {
          "type": "string",
          "minLength": 1,
          "examples": ["s-black", "wangcai", "dabai", "all"]
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "runtime": {
      "type": "object",
      "required": ["kind", "call_method"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["qwenpaw_agent", "acp_runner", "cli_tool", "external_service", "manual"]
        },
        "call_method": {
          "type": "string",
          "minLength": 1
        },
        "agent_id": {
          "type": ["string", "null"]
        },
        "runner": {
          "type": ["string", "null"]
        },
        "command": {
          "type": ["string", "null"]
        },
        "workspace": {
          "type": ["string", "null"]
        }
      }
    },
    "handoff": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "can_receive_from": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "can_delegate_to": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "default_reviewer": {
          "type": ["string", "null"]
        },
        "requires_review": {
          "type": "boolean"
        }
      }
    },
    "cost_profile": {
      "type": "object",
      "required": ["cost_level"],
      "additionalProperties": false,
      "properties": {
        "cost_level": {
          "type": "string",
          "enum": ["low", "medium", "high", "unknown"]
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
