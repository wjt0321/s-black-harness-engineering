{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://s-black-harness-engineering.local/schemas/execution-envelope.schema.json",
  "title": "Adapter Execution Envelope Artifacts",
  "type": "object",
  "required": ["version", "description", "artifacts"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "description": {
      "type": "string"
    },
    "artifacts": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifact" },
      "minItems": 1
    }
  },
  "$defs": {
    "artifact": {
      "oneOf": [
        { "$ref": "#/$defs/adapter_request" },
        { "$ref": "#/$defs/adapter_response" },
        { "$ref": "#/$defs/approval_record" },
        { "$ref": "#/$defs/execution_event" }
      ]
    },
    "id_string": {
      "type": "string",
      "pattern": "^[a-z]+-[0-9]{8}-[0-9]{3,}$"
    },
    "task_id": {
      "type": "string",
      "pattern": "^task-[0-9]{8}-[0-9]{3,}$"
    },
    "safe_string": {
      "type": "string",
      "minLength": 1
    },
    "finding": {
      "type": "object",
      "required": ["rule_id", "severity", "action", "message"],
      "additionalProperties": false,
      "properties": {
        "rule_id": { "$ref": "#/$defs/safe_string" },
        "severity": {
          "type": "string",
          "enum": ["info", "warn", "block"]
        },
        "action": { "$ref": "#/$defs/safe_string" },
        "message": { "$ref": "#/$defs/safe_string" }
      }
    },
    "evidence": {
      "type": "object",
      "required": ["type", "description"],
      "additionalProperties": false,
      "properties": {
        "type": { "$ref": "#/$defs/safe_string" },
        "description": { "$ref": "#/$defs/safe_string" },
        "ref": { "type": ["string", "null"] }
      }
    },
    "approval_scope": {
      "type": "object",
      "required": ["task_id", "adapter_id", "operation", "target"],
      "additionalProperties": false,
      "properties": {
        "task_id": { "$ref": "#/$defs/task_id" },
        "adapter_id": { "$ref": "#/$defs/safe_string" },
        "operation": { "$ref": "#/$defs/safe_string" },
        "target": { "$ref": "#/$defs/safe_string" }
      }
    },
    "adapter_request": {
      "type": "object",
      "required": [
        "artifact_type",
        "request_id",
        "task_id",
        "adapter_id",
        "operation",
        "actor",
        "target",
        "input",
        "context",
        "preflight",
        "created_at"
      ],
      "additionalProperties": false,
      "properties": {
        "artifact_type": { "const": "adapter_request" },
        "request_id": { "$ref": "#/$defs/id_string" },
        "task_id": { "$ref": "#/$defs/task_id" },
        "adapter_id": { "$ref": "#/$defs/safe_string" },
        "operation": { "$ref": "#/$defs/safe_string" },
        "actor": { "$ref": "#/$defs/safe_string" },
        "target": { "$ref": "#/$defs/safe_string" },
        "input": {
          "type": "object",
          "additionalProperties": true
        },
        "context": {
          "type": "object",
          "required": ["source", "policy_profile", "risk_level", "dry_run", "requires_approval"],
          "additionalProperties": true,
          "properties": {
            "source": { "$ref": "#/$defs/safe_string" },
            "policy_profile": { "$ref": "#/$defs/safe_string" },
            "risk_level": {
              "type": "string",
              "enum": ["local", "external", "destructive", "privileged"]
            },
            "dry_run": { "type": "boolean" },
            "requires_approval": { "type": "boolean" },
            "approval_id": { "type": ["string", "null"] },
            "payload_refs": {
              "type": "array",
              "items": { "type": "string" },
              "uniqueItems": true
            }
          }
        },
        "preflight": {
          "type": "object",
          "required": ["status", "findings"],
          "additionalProperties": false,
          "properties": {
            "status": {
              "type": "string",
              "enum": ["pass", "warn", "blocked", "needs_approval", "needs_input", "error"]
            },
            "findings": {
              "type": "array",
              "items": { "$ref": "#/$defs/finding" }
            }
          }
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "adapter_response": {
      "type": "object",
      "required": [
        "artifact_type",
        "response_id",
        "request_id",
        "status",
        "message",
        "artifacts",
        "evidence",
        "raw_ref",
        "error",
        "finished_at"
      ],
      "additionalProperties": false,
      "properties": {
        "artifact_type": { "const": "adapter_response" },
        "response_id": { "$ref": "#/$defs/id_string" },
        "request_id": { "$ref": "#/$defs/id_string" },
        "status": {
          "type": "string",
          "enum": ["succeeded", "blocked", "failed", "needs_approval", "needs_input", "skipped"]
        },
        "message": { "$ref": "#/$defs/safe_string" },
        "artifacts": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence" }
        },
        "raw_ref": { "type": ["string", "null"] },
        "error": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "properties": {
            "code": { "$ref": "#/$defs/safe_string" },
            "message": { "$ref": "#/$defs/safe_string" }
          }
        },
        "finished_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "approval_record": {
      "type": "object",
      "required": [
        "artifact_type",
        "approval_id",
        "request_id",
        "status",
        "scope",
        "requested_at",
        "decided_at",
        "decided_by",
        "decision_ref"
      ],
      "additionalProperties": false,
      "properties": {
        "artifact_type": { "const": "approval_record" },
        "approval_id": { "$ref": "#/$defs/id_string" },
        "request_id": { "$ref": "#/$defs/id_string" },
        "status": {
          "type": "string",
          "enum": ["pending", "granted", "denied", "expired"]
        },
        "scope": { "$ref": "#/$defs/approval_scope" },
        "requested_at": {
          "type": "string",
          "format": "date-time"
        },
        "decided_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "decided_by": { "type": ["string", "null"] },
        "decision_ref": { "type": ["string", "null"] }
      }
    },
    "execution_event": {
      "type": "object",
      "required": [
        "artifact_type",
        "event_id",
        "task_id",
        "request_id",
        "timestamp",
        "actor",
        "event_type",
        "message",
        "metadata"
      ],
      "additionalProperties": false,
      "properties": {
        "artifact_type": { "const": "execution_event" },
        "event_id": { "$ref": "#/$defs/id_string" },
        "task_id": { "$ref": "#/$defs/task_id" },
        "request_id": { "$ref": "#/$defs/id_string" },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "actor": { "$ref": "#/$defs/safe_string" },
        "event_type": {
          "type": "string",
          "enum": [
            "adapter_preflight",
            "approval_requested",
            "approval_recorded",
            "adapter_invocation_planned",
            "adapter_response_recorded",
            "evidence_added",
            "postflight_checked"
          ]
        },
        "message": { "$ref": "#/$defs/safe_string" },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
